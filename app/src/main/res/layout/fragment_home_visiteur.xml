<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".ui.visiteur.HomeVisiteurFragment">

    <!-- Titre -->
    <TextView
        android:id="@+id/tvTitre"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="GSB Visites - Home"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:paddingBottom="12dp" />

    <!-- Bonjour Prénom Nom -->
    <TextView
        android:id="@+id/tvBonjour"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bonjour ..."
        android:textSize="16sp"
        android:paddingBottom="16dp"
        tools:text="Bonjour Jean Dupont" />

    <!-- RecyclerView Praticiens -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewPraticien"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="16dp"
        android:layout_weight="1" />

    <!-- Bouton Créer un praticien -->
    <Button
        android:id="@+id/btnCreerPraticien"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Créer un praticien" />

</LinearLayout>